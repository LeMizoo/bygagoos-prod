# ============================================
# SERVEUR
# ============================================
PORT=5000
NODE_ENV=development
API_PREFIX=/api/v1
HOST=localhost

# ============================================
# BASE DE DONNÉES MONGODB
# ============================================
# URI de connexion MongoDB (Atlas ou local)
MONGODB_URI=mongodb+srv://bygagoos:bygagoos123@cluster0.w8joq0e.mongodb.net/bygagoos-ink?retryWrites=true&w=majority
# URI pour les tests (optionnel)
MONGODB_URI_TEST=mongodb+srv://bygagoos:bygagoos123@cluster0.w8joq0e.mongodb.net/bygagoos-ink-test?retryWrites=true&w=majority
# Utiliser MongoDB (toujours true)
USE_MONGODB=true

# Options de connexion MongoDB
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_CONNECT_TIMEOUT_MS=30000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# ============================================
# JWT (JSON Web Tokens)
# ============================================
# Clé secrète pour les tokens d'accès (minimum 32 caractères)
JWT_ACCESS_SECRET=36958e45e50033a39252dc9e883fc739a4c6dab37e634511e2fc4ca9e72de552de9f480ed9232e468eaf4cccd6ca9e1a17b41915b92b670ab0e2ce3e4457e931
# Clé secrète pour les tokens de rafraîchissement (minimum 32 caractères)
JWT_REFRESH_SECRET=7a4c6dab37e634511e2fc4ca9e72de552de9f480ed9232e468eaf4cccd6ca9e1a17b41915b92b670ab0e2ce3e4457e93136958e45e50033a39252dc9e883fc7
# Durée de validité du token d'accès (15m = 15 minutes, 1h = 1 heure)
JWT_ACCESS_EXPIRE=15m
# Alias pour compatibilité
JWT_ACCESS_EXPIRES_IN=15m
# Durée de validité du token de rafraîchissement (7d = 7 jours)
JWT_REFRESH_EXPIRE=7d
# Alias pour compatibilité
JWT_REFRESH_EXPIRES_IN=7d
# Nombre de rounds pour le hash bcrypt (10-12 recommandé)
BCRYPT_ROUNDS=12

# ============================================
# CLOUDINARY (Stockage d'images)
# ============================================
# Nom du cloud Cloudinary
CLOUDINARY_CLOUD_NAME=byGagoosInk
# Clé API Cloudinary
CLOUDINARY_API_KEY=568768628613676
# Secret API Cloudinary
CLOUDINARY_API_SECRET=1fbz7nk4KxQlxNezfktIYwb5LeI
# Dossier par défaut pour les uploads
CLOUDINARY_FOLDER=bygagoos-ink
# Dossier pour les designs
CLOUDINARY_DESIGNS_FOLDER=bygagoos-ink/designs
# Dossier pour les avatars
CLOUDINARY_AVATARS_FOLDER=bygagoos-ink/avatars

# ============================================
# CORS ET FRONTEND
# ============================================
# URL du frontend en développement
FRONTEND_URL_DEV=http://localhost:5173
# URL alternative du frontend
FRONTEND_URL_DEV_ALT=http://localhost:3000
# URL du frontend en production (à décommenter en prod)
# FRONTEND_URL_PROD=https://bygagoos-ink.vercel.app
# Origines autorisées pour CORS (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5000
# Activer les credentials CORS
CORS_CREDENTIALS=true

# ============================================
# SÉCURITÉ ET RATE LIMITING
# ============================================
# Fenêtre de temps pour le rate limiting (en ms) - 15 minutes
RATE_LIMIT_WINDOW_MS=900000
# Nombre maximum de requêtes par fenêtre
RATE_LIMIT_MAX=100
# Fenêtre pour l'authentification (plus stricte) - 15 minutes
AUTH_RATE_LIMIT_WINDOW_MS=900000
# Nombre maximum de tentatives d'auth
AUTH_RATE_LIMIT_MAX=20
# Clé secrète pour les sessions (optionnel)
SESSION_SECRET=bygagoos-ink-session-secret-key-2024

# ============================================
# UPLOAD DE FICHERS
# ============================================
# Taille maximale des fichiers (en octets) - 5 Mo
MAX_FILE_SIZE=5242880
# Types de fichiers autorisés
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf
# Nombre maximal de fichiers par upload
MAX_FILES_PER_UPLOAD=10

# ============================================
# LOGGING
# ============================================
# Niveau de log (debug, info, warn, error)
LOG_LEVEL=debug
# Dossier pour les logs
LOG_DIR=logs
# Activer les logs en console
LOG_CONSOLE=true
# Activer les logs dans des fichiers
LOG_FILE=true
# Format des logs (json, simple)
LOG_FORMAT=simple

# ============================================
# EMAIL (SMTP)
# ============================================
# Hôte SMTP (Gmail: smtp.gmail.com)
SMTP_HOST=smtp.gmail.com
# Port SMTP (587 pour TLS, 465 pour SSL)
SMTP_PORT=587
# Sécuriser la connexion (true pour 465, false pour 587)
SMTP_SECURE=false
# Utilisateur SMTP (votre email)
SMTP_USER=votre-email@gmail.com
# Mot de passe SMTP (mot de passe d'application pour Gmail)
SMTP_PASS=votre-mot-de-passe-app
# Email d'expédition
EMAIL_FROM=noreply@bygagoos-ink.com
# Nom d'expédition
EMAIL_FROM_NAME=ByGagoos Ink

# ============================================
# REDIS (Cache et Refresh Tokens)
# ============================================
# URL de connexion Redis
REDIS_URL=redis://localhost:6379
# Hôte Redis (si pas d'URL)
REDIS_HOST=localhost
# Port Redis
REDIS_PORT=6379
# Mot de passe Redis (si nécessaire)
REDIS_PASSWORD=
# Activer TLS pour Redis
REDIS_TLS=false
# Activer le cache Redis
REDIS_CACHE_ENABLED=true
# Durée de vie du cache (en secondes) - 5 minutes
REDIS_CACHE_TTL=300
# Préfixe pour les clés Redis
REDIS_KEY_PREFIX=bygagoos:

# ============================================
# REFRESH TOKENS (Redis)
# ============================================
# Durée de vie des refresh tokens dans Redis (en secondes) - 7 jours
REDIS_REFRESH_TOKEN_TTL=604800
# Activer la rotation des refresh tokens
REFRESH_TOKEN_ROTATION=true
# Blacklister les anciens tokens après rotation
REFRESH_TOKEN_BLACKLIST=true

# ============================================
# PAGINATION
# ============================================
# Limite par défaut pour la pagination
DEFAULT_PAGE_LIMIT=20
# Limite maximale pour la pagination
MAX_PAGE_LIMIT=100

# ============================================
# ADMIN PAR DÉFAUT
# ============================================
# Créer un admin par défaut au premier lancement
CREATE_DEFAULT_ADMIN=true
# Email de l'admin par défaut
DEFAULT_ADMIN_EMAIL=admin@bygagoos.com
# Mot de passe de l'admin par défaut
DEFAULT_ADMIN_PASSWORD=Admin123!
# Nom de l'admin par défaut
DEFAULT_ADMIN_NAME=Administrateur

# ============================================
# WEBHOOKS
# ============================================
# URL du webhook pour les paiements
PAYMENT_WEBHOOK_URL=
# Secret pour les webhooks
WEBHOOK_SECRET=bygagoos-webhook-secret-2024

# ============================================
# ENVIRONNEMENT DE PRODUCTION (À DÉCOMMENTER EN PROD)
# ============================================
# NODE_ENV=production
# FRONTEND_URL=https://bygagoos-ink.vercel.app
# ALLOWED_ORIGINS=https://bygagoos-ink.vercel.app
# LOG_LEVEL=warn
# REDIS_CACHE_ENABLED=true
# CREATE_DEFAULT_ADMIN=false