{
  "compilerOptions": {
    /* Langue et Environnement */
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "ignoreDeprecations": 6,

    /* Sortie et Structure */
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",                   // ← AJOUTÉ (crucial)

    /* Résolution de modules */
    "paths": {
      "@/*": ["*"],
      "@config/*": ["config/*"],
      "@core/*": ["core/*"],
      "@middlewares/*": ["middlewares/*"],
      "@modules/*": ["modules/*"],
      "@utils/*": ["utils/*"],
      "@types/*": ["types/*"],
      "@redis/*": ["core/config/*"]
    },
    "resolveJsonModule": true,

    /* Interop et compatibilité */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleDetection": "force",
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "types": ["node", "express"],

    /* Émission et Compilation */
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true,
    "noEmit": false,
    "noEmitOnError": false,
    "incremental": false,

    /* Vérification stricte */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": false,
    "noUncheckedIndexedAccess": false,
    "allowUnreachableCode": true,
    "allowUnusedLabels": true,
    "strictPropertyInitialization": false,
    "strictNullChecks": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "coverage", "scripts"],
  "ts-node": {
    "files": true,
    "require": ["tsconfig-paths/register"],
    "transpileOnly": true,
    "compilerOptions": {
      "module": "CommonJS",
      "target": "ES2020",
      "strict": false,
      "noImplicitAny": false
    }
  }
}