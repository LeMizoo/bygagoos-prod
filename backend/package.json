{
  "name": "bygagoos-ink-backend",
  "version": "2.0.0",
  "description": "Backend API pour ByGagoos-Ink - Gestion de designs, commandes et utilisateurs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec npx tsx -r tsconfig-paths/register src/index.ts",
    "dev:with-redis": "concurrently \"npm:redis:start\" \"npm:dev\"",
    "build": "tsc -p tsconfig.json",
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "clean": "rimraf dist",
    "clean:all": "rimraf dist dist-scripts node_modules package-lock.json",
    "clean:scripts": "rimraf dist-scripts",
    "reinstall": "npm run clean:all && npm install",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "type-check:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "seed": "ts-node -r tsconfig-paths/register src/utils/seed/index.ts",
    "prepare": "husky install",
    "prebuild": "npm run clean",
    "redis:start": "node scripts/start-redis.js",
    "redis:stop": "node scripts/stop-redis.js",
    "redis:status": "node scripts/redis-status.js",
    "redis:info": "node scripts/redis-info.js",
    "redis:test": "node scripts/test-redis-connection.js",
    "redis:monitor": "node scripts/monitor-redis.js",
    "redis:docker": "docker run -d --name redis-bygagoos -p 6379:6379 redis:alpine",
    "redis:docker:stop": "docker stop redis-bygagoos && docker rm redis-bygagoos",
    "check:users": "node scripts/check-user-model.js",
    "migrate:roles": "node scripts/migrate-user-roles.js"
  },
  "keywords": [
    "express",
    "mongodb",
    "typescript",
    "api",
    "cloudinary",
    "jwt",
    "authentication",
    "design",
    "orders",
    "clients",
    "bygagoos",
    "printing",
    "ecommerce",
    "redis"
  ],
  "author": {
    "name": "ByGagoos Family",
    "email": "contact@bygagoos.com",
    "url": "https://bygagoos.com"
  },
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.7.4",
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "redis": "^4.6.11",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.1.1",
    "rimraf": "^6.1.3",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@redis/(.*)$": "<rootDir>/src/core/config/$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/src/test/setup.ts"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      "/dist-scripts/",
      "/src/test/",
      "/src/scripts/"
    ]
  }
}