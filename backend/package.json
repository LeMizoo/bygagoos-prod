{
  "name": "bygagoos-ink-backend",
  "version": "2.1.0",
  "description": "Backend API pour ByGagoos-Ink - Gestion de designs, commandes et utilisateurs",
  "private": true,
  "main": "dist/index.js",
  "author": {
    "name": "ByGagoos Family",
    "email": "contact@bygagoos.com",
    "url": "https://bygagoos.com"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },

  "scripts": {
    "dev": "nodemon --exec tsx -r tsconfig-paths/register src/index.ts",
    "dev:quiet": "set NODE_NO_WARNINGS=1 && nodemon --exec tsx -r tsconfig-paths/register src/index.ts",
    "dev:redis": "concurrently \"npm run redis:start\" \"npm run dev\"",

    "build": "tsc",
    "build:scripts": "tsc -p tsconfig.scripts.json",

    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",

    "clean": "rimraf dist",
    "clean:all": "rimraf dist node_modules package-lock.json",

    "reinstall": "npm run clean:all && npm install",

    "type-check": "tsc --noEmit",

    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",

    "format": "prettier --write \"src/**/*.ts\"",

    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",

    "seed": "ts-node -r tsconfig-paths/register src/utils/seed/index.ts",

    "reset:password": "ts-node src/scripts/reset-password.ts",
    "create:staff": "ts-node src/scripts/create-staff.ts",

    "redis:start": "node scripts/start-redis.js",
    "redis:stop": "node scripts/stop-redis.js",
    "redis:status": "node scripts/redis-status.js",
    "redis:test": "node scripts/test-redis-connection.js",

    "cron:start": "node dist/jobs/emailReminders.js",
    "cron:dev": "ts-node src/jobs/emailReminders.ts",

    "upload:clean": "node scripts/clean-uploads.js",
    "upload:optimize": "node scripts/optimize-uploads.js",

    "email:test": "ts-node src/scripts/test-email.ts",

    "prebuild": "npm run clean",
    "postinstall": "npm run type-check",
    "precommit": "lint-staged",
    "prepush": "npm test"
  },

  "keywords": [
    "express",
    "mongodb",
    "typescript",
    "api",
    "cloudinary",
    "jwt",
    "authentication",
    "design",
    "orders",
    "clients",
    "bygagoos",
    "printing",
    "ecommerce",
    "redis",
    "printing-shop",
    "custom-designs",
    "pdf-generation",
    "email-notifications",
    "file-upload",
    "image-optimization"
  ],

  "dependencies": {
    "axios": "^1.13.5",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.7.4",
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "googleapis": "^128.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.14.0",
    "redis": "^4.6.11",
    "sharp": "^0.33.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.22.4"
  },

  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.23",
    "@types/pdfkit": "^0.13.9",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.1.1",
    "rimraf": "^6.1.3",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },

  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/src/test/setup.ts"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      "/src/test/",
      "/src/scripts/",
      "/src/jobs/"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ]
  },

  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}