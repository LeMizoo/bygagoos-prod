{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": ["frontend/src/**/*", "backend/src/**/*", "backend/scripts/fix-catch-clauses.js"],
  "exclude": ["node_modules", "dist"]
}